      "typeBits": 4,
      "variationBits": 28,
      "types": {
        "0": "terran_temperate",
        "1": "desert_world",
        "2": "ice_world",
        "3": "ocean_world",
        "4": "super_earth",
        "5": "martian",
        "6": "jovian",
